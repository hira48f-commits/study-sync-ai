import React, { useState } from "react";
import { Users, Plus, MessageSquare, BookOpen, Share2, Send, CheckCircle2, Copy, Check } from "lucide-react";
import { StudyGroup } from "../types";

export const StudyGroupsView: React.FC = () => {
  const [groups, setGroups] = useState<StudyGroup[]>([
    {
      id: "grp-1",
      name: "Stanford Pre-Med Bio Circle",
      subject: "Biochemistry & Neurobiology",
      inviteCode: "BIO-9921",
      membersCount: 4,
      sharedNotesCount: 5,
      chatMessages: [
        { id: "m1", sender: "Sophia", text: "Hey team, did anyone review the NMDA unblocking diagram?", timestamp: "10:15 AM" },
        { id: "m2", sender: "David", text: "Yes! The flashcard set in our group repository clarifies it nicely.", timestamp: "10:18 AM" }
      ]
    },
    {
      id: "grp-2",
      name: "MIT CS Algo Squad",
      subject: "Computer Science",
      inviteCode: "CS-8810",
      membersCount: 3,
      sharedNotesCount: 3,
      chatMessages: [
        { id: "m1", sender: "Alex", text: "Practice quiz #3 for Graph Theory is live!", timestamp: "Yesterday" }
      ]
    }
  ]);

  const [activeGroup, setActiveGroup] = useState<StudyGroup>(groups[0]);
  const [newMsg, setNewMsg] = useState("");
  const [copiedCode, setCopiedCode] = useState(false);
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [newGroupName, setNewGroupName] = useState("");
  const [newGroupSubject, setNewGroupSubject] = useState("");

  const handleSendMessage = (e: React.FormEvent) => {
    e.preventDefault();
    if (!newMsg.trim()) return;

    const updatedGroup = {
      ...activeGroup,
      chatMessages: [
        ...activeGroup.chatMessages,
        { id: `m-${Date.now()}`, sender: "You", text: newMsg, timestamp: "Just now" }
      ]
    };

    setActiveGroup(updatedGroup);
    setGroups(groups.map((g) => (g.id === activeGroup.id ? updatedGroup : g)));
    setNewMsg("");
  };

  const handleCopyCode = () => {
    navigator.clipboard.writeText(activeGroup.inviteCode);
    setCopiedCode(true);
    setTimeout(() => setCopiedCode(false), 2000);
  };

  const handleCreateGroup = (e: React.FormEvent) => {
    e.preventDefault();
    if (!newGroupName) return;

    const created: StudyGroup = {
      id: `grp-${Date.now()}`,
      name: newGroupName,
      subject: newGroupSubject || "General Study",
      inviteCode: `STUDY-${Math.floor(1000 + Math.random() * 9000)}`,
      membersCount: 1,
      sharedNotesCount: 1,
      chatMessages: [
        { id: "m0", sender: "System", text: "Study group created! Invite classmates with code.", timestamp: "Just now" }
      ]
    };

    setGroups([...groups, created]);
    setActiveGroup(created);
    setNewGroupName("");
    setNewGroupSubject("");
    setIsModalOpen(false);
  };

  return (
    <div className="space-y-6 animate-in fade-in duration-300">
      {/* Header */}
      <div className="p-6 rounded-3xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 className="text-2xl font-extrabold text-slate-900 dark:text-white flex items-center gap-2.5">
            <Users className="w-6 h-6 text-indigo-500" />
            <span>Study Groups & Collaborative Circles</span>
          </h1>
          <p className="text-xs text-slate-500 dark:text-slate-400">
            Share study sets, flashcards, practice quizzes, and discuss challenging concepts with classmates
          </p>
        </div>

        <button
          onClick={() => setIsModalOpen(true)}
          className="px-5 py-3 rounded-2xl bg-gradient-to-r from-indigo-600 to-cyan-500 text-white font-bold text-xs shadow-lg shadow-indigo-500/20 hover:from-indigo-500 transition flex items-center justify-center gap-2"
        >
          <Plus className="w-4 h-4" />
          <span>Create / Join Group</span>
        </button>
      </div>

      {/* Main Grid: Groups List & Group Chat Workspace */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Col: Groups list */}
        <div className="space-y-3">
          <h3 className="text-xs font-bold uppercase tracking-wider text-slate-500 px-1">
            My Study Groups ({groups.length})
          </h3>
          {groups.map((grp) => (
            <div
              key={grp.id}
              onClick={() => setActiveGroup(grp)}
              className={`p-4 rounded-2xl border transition cursor-pointer ${
                activeGroup.id === grp.id
                  ? "bg-indigo-600 text-white border-indigo-600 shadow-lg shadow-indigo-500/20"
                  : "bg-white dark:bg-slate-900 border-slate-200 dark:border-slate-800 text-slate-900 dark:text-white hover:border-indigo-500"
              }`}
            >
              <div className="flex items-center justify-between mb-1">
                <span
                  className={`text-[10px] font-bold px-2 py-0.5 rounded-full uppercase ${
                    activeGroup.id === grp.id
                      ? "bg-white/20 text-white"
                      : "bg-indigo-500/10 text-indigo-500"
                  }`}
                >
                  {grp.subject}
                </span>
                <span className="text-[10px] font-mono opacity-80">{grp.membersCount} Members</span>
              </div>
              <h4 className="text-sm font-bold">{grp.name}</h4>
              <p className="text-[11px] opacity-80 mt-1">{grp.sharedNotesCount} Shared Notes</p>
            </div>
          ))}
        </div>

        {/* Right Col (2 cols): Active Group Discussion & Repository */}
        <div className="lg:col-span-2 p-6 rounded-3xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800/80 shadow-sm flex flex-col h-[520px]">
          {/* Active Group Header */}
          <div className="flex items-center justify-between pb-4 border-b border-slate-100 dark:border-slate-800 shrink-0">
            <div>
              <h3 className="text-base font-bold text-slate-900 dark:text-white">{activeGroup.name}</h3>
              <p className="text-xs text-slate-500 dark:text-slate-400">
                {activeGroup.subject} • {activeGroup.membersCount} Classmates Active
              </p>
            </div>

            <button
              onClick={handleCopyCode}
              className="px-3 py-1.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-xs font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-200 transition flex items-center gap-1.5 font-mono"
            >
              {copiedCode ? <Check className="w-3.5 h-3.5 text-emerald-500" /> : <Copy className="w-3.5 h-3.5" />}
              <span>Code: {activeGroup.inviteCode}</span>
            </button>
          </div>

          {/* Group Chat Messages */}
          <div className="flex-1 overflow-y-auto space-y-3 py-4">
            {(activeGroup?.chatMessages || []).map((m) => (
              <div key={m.id} className="space-y-1">
                <div className="flex items-center gap-2 text-[10px] text-slate-400">
                  <span className="font-bold text-indigo-500">{m.sender}</span>
                  <span>• {m.timestamp}</span>
                </div>
                <div className="p-3 rounded-2xl bg-slate-50 dark:bg-slate-800/60 border border-slate-100 dark:border-slate-800 text-xs text-slate-800 dark:text-slate-200 max-w-md">
                  {m.text}
                </div>
              </div>
            ))}
          </div>

          {/* Send Input */}
          <form onSubmit={handleSendMessage} className="pt-3 border-t border-slate-100 dark:border-slate-800 shrink-0 flex gap-2">
            <input
              type="text"
              value={newMsg}
              onChange={(e) => setNewMsg(e.target.value)}
              placeholder="Post a message or question to your study circle..."
              className="flex-1 px-4 py-2 text-xs rounded-xl bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white focus:outline-none focus:border-indigo-500"
            />
            <button
              type="submit"
              className="px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-xs transition flex items-center gap-1"
            >
              <Send className="w-3.5 h-3.5" />
            </button>
          </form>
        </div>
      </div>

      {/* Modal */}
      {isModalOpen && (
        <div className="fixed inset-0 z-50 bg-slate-900/70 backdrop-blur-md flex items-center justify-center p-4">
          <div className="w-full max-w-md bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 shadow-2xl space-y-4">
            <h3 className="text-lg font-bold text-slate-900 dark:text-white">Create Study Group</h3>
            <form onSubmit={handleCreateGroup} className="space-y-3">
              <div>
                <label className="block text-xs font-bold mb-1">Group Name</label>
                <input
                  type="text"
                  required
                  value={newGroupName}
                  onChange={(e) => setNewGroupName(e.target.value)}
                  placeholder="e.g. Organic Chemistry Study Circle"
                  className="w-full p-2.5 text-xs rounded-xl bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700"
                />
              </div>
              <div>
                <label className="block text-xs font-bold mb-1">Subject</label>
                <input
                  type="text"
                  required
                  value={newGroupSubject}
                  onChange={(e) => setNewGroupSubject(e.target.value)}
                  placeholder="e.g. Chemistry"
                  className="w-full p-2.5 text-xs rounded-xl bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700"
                />
              </div>
              <div className="flex justify-end gap-2 pt-2">
                <button
                  type="button"
                  onClick={() => setIsModalOpen(false)}
                  className="px-4 py-2 rounded-xl text-xs font-bold bg-slate-100 dark:bg-slate-800"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  className="px-4 py-2 rounded-xl bg-indigo-600 text-white text-xs font-bold"
                >
                  Create Group
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};
